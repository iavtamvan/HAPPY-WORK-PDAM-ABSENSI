<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom layer: top-bar warna penuh selebar card -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F59E0B" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Top layer: card body putih, dengan top inset 4dp supaya warna bawahnya muncul jadi top-bar -->
    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="#E6E0E1" />
        </shape>
    </item>
</layer-list>