<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="co.id.pdamkotasmg.ui.activity.RiwayatPembacaMeterActivity">

<!--    <include layout="@layout/content_header" />-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/iv_header_back_arrow"
                android:layout_width="30dp"
                android:layout_height="50dp"
                android:src="@drawable/arrrow_left" />

            <TextView
                android:fontFamily="@font/poppins"
                android:id="@+id/tv_header_judul"
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:gravity="left|center"
                android:paddingLeft="10dp"
                android:text="Judul"
                android:textColor="@color/black"
                android:textStyle="bold"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="right">

            <ImageView
                android:id="@+id/iv_header_info"
                android:layout_width="25dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/info" />

        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="8dp"
        tools:listitem="@layout/item_list_riwayat_pembaca_meter"/>
    
</LinearLayout>