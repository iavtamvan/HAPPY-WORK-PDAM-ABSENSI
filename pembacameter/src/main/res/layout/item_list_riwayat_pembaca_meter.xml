<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cvKlik"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="3dp"
    android:orientation="vertical"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_klik"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:layout_marginTop="4dp"
            android:layout_marginRight="4dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="8dp"
                android:layout_marginBottom="5dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="ID Pelanggan: "
                                            android:textColor="@color/grey"
                                            android:textSize="10dp" />

                                        <TextView
                                            android:id="@+id/tv_list_nolangg"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="05200401"
                                            android:textColor="@color/red"
                                            android:textSize="13dp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="DISM: "
                                            android:textColor="@color/grey"
                                            android:textSize="10dp" />

                                        <TextView
                                            android:id="@+id/tv_list_dism"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="5261004"
                                            android:textColor="@color/black"
                                            android:textSize="13dp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="Periode: "
                                            android:textColor="@color/grey"
                                            android:textSize="10dp" />

                                        <TextView
                                            android:id="@+id/tv_list_periode"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="202309"
                                            android:textColor="@color/black"
                                            android:textSize="13dp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="Stand: "
                                            android:textColor="@color/grey"
                                            android:textSize="10dp" />

                                        <TextView
                                            android:id="@+id/tv_list_stand"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="2333"
                                            android:textColor="@color/black"
                                            android:textSize="13dp" />
                                    </LinearLayout>
                                </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="5dp"
                                        android:gravity="left"
                                        android:text="Nama: "
                                        android:textColor="@color/grey"
                                        android:textSize="10dp" />

                                    <TextView
                                        android:id="@+id/tv_list_nama"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="left"
                                        android:text="Gedung Wanita Setda Prov.	"
                                        android:textColor="@color/black"
                                        android:textSize="13dp" />

                                </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="5dp"
                                            android:gravity="left"
                                            android:text="Status Meter: "
                                            android:textColor="@color/grey"
                                            android:textSize="10dp" />

                                        <TextView
                                            android:id="@+id/tv_status_meter"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="GEMBOK"
                                            android:textColor="@color/black"
                                            android:textSize="13dp" />

                                    </LinearLayout>
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="5dp"
                                            android:gravity="left"
                                            android:text="Alamt: "
                                            android:textColor="@color/grey"
                                            android:textSize="10dp" />

                                        <TextView
                                            android:id="@+id/tv_alamat"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:gravity="left"
                                            android:text="Madukoro AA/BB"
                                            android:textColor="@color/black"
                                            android:textSize="13dp" />

                                    </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_list_tgl_jam_baca"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginRight="8dp"
                                android:gravity="left|center_vertical"
                                android:text="2023-09-01 15:48:45"
                                android:textColor="@color/grey"
                                android:textSize="11dp"
                                android:textStyle="italic" />

                            <TextView
                                android:id="@+id/tv_list_status_dibaca"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="10dp"
                                android:gravity="left|center_vertical"
                                android:visibility="gone"
                                android:text="Sudah dibaca"
                                android:textColor="@color/greenGojek"
                                android:textSize="12dp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/iv_success_req"
                                android:layout_width="20dp"
                                android:layout_height="match_parent"
                                android:src="@drawable/succes_req"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/iv_close_req"
                                android:layout_width="20dp"
                                android:layout_height="match_parent"
                                android:src="@drawable/close_req"
                                android:visibility="gone" />

                        </LinearLayout>


                    </LinearLayout>
                </LinearLayout>


            </LinearLayout>
        </androidx.cardview.widget.CardView>


    </LinearLayout>


</LinearLayout>