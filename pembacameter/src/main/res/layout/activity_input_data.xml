<?xml version="1.0" encoding="utf-8"?>
<!--
  REDESIGN activity_input_data.xml — Material 3 form.
  - Form dibungkus card putih rounded
  - Cabang & Periode jadi info block 2-kolom (read-only)
  - Bendel input pakai TextInputLayout outlined
  - Form hint banner kuning
  - Tombol "Buka Data" sticky di bawah, pill-shape, full width
  - 4 section dipertahankan (bendel, per_pelanggan, per_foto_meter, baca_ulang)
    — Java toggle visibility-nya berdasarkan menu yang dipilih.

  SEMUA ID dipertahankan:
    div_input_bendel, tv_bendel_cabang, tv_bendel_periode, edt_bendel,
    div_input_per_pelanggan, edt_pelanggan,
    div_input_per_foto_meter, iv_foto_meter, btn_pilih_foto_meter, edt_pelanggan_foto_meter,
    div_input_baca_ulang, edt_pelanggan_baca_ulang,
    btn_buka_data.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF9F8"
    android:orientation="vertical"
    tools:context="co.id.pdamkotasmg.ui.activity.bendel.InputDataActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- ═══════════ SECTION: BENDEL ═══════════ -->
            <LinearLayout
                android:id="@+id/div_input_bendel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E6E0E1"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:letterSpacing="0.08"
                            android:text="INFORMASI AKTIF"
                            android:textColor="#6B6770"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <!-- Cabang & Periode (info blocks 2 kolom) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_info_block"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:letterSpacing="0.04"
                                    android:text="CABANG"
                                    android:textColor="#6B6770"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tv_bendel_cabang"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:text="-"
                                    android:textColor="#1C1B1F"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_info_block"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:letterSpacing="0.04"
                                    android:text="PERIODE"
                                    android:textColor="#6B6770"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tv_bendel_periode"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:text="-"
                                    android:textColor="#1C1B1F"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Bendel input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:hint="Nomor Bendel"
                            app:boxBackgroundColor="#FFFFFF"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxStrokeColor="#C8102E"
                            app:boxStrokeWidth="1.5dp"
                            app:helperText="Contoh: 2493 (4 digit nomor bendel)"
                            app:helperTextTextColor="#6B6770"
                            app:hintTextColor="#C8102E"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_bendel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:inputType="number"
                                android:maxLength="4"
                                android:textSize="15sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Form hint -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_form_hint"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_info_orange" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/poppins"
                        android:text="Pastikan periode dan cabang sudah sesuai sebelum membuka bendel."
                        android:textColor="#78350F"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══════════ SECTION: PER PELANGGAN ═══════════ -->
            <LinearLayout
                android:id="@+id/div_input_per_pelanggan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E6E0E1"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:letterSpacing="0.08"
                            android:text="INFORMASI AKTIF"
                            android:textColor="#6B6770"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_info_block"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:letterSpacing="0.04"
                                    android:text="CABANG"
                                    android:textColor="#6B6770"
                                    android:textSize="10sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:text="-"
                                    android:textColor="#1C1B1F"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_info_block"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:letterSpacing="0.04"
                                    android:text="PERIODE"
                                    android:textColor="#6B6770"
                                    android:textSize="10sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:text="-"
                                    android:textColor="#1C1B1F"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:hint="ID Pelanggan"
                            app:boxBackgroundColor="#FFFFFF"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxStrokeColor="#C8102E"
                            app:boxStrokeWidth="1.5dp"
                            app:hintTextColor="#C8102E"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_pelanggan"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:textSize="15sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ═══════════ SECTION: PER FOTO METER ═══════════ -->
            <LinearLayout
                android:id="@+id/div_input_per_foto_meter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E6E0E1"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:letterSpacing="0.08"
                            android:text="INFORMASI AKTIF"
                            android:textColor="#6B6770"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_info_block"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:letterSpacing="0.04"
                                    android:text="CABANG"
                                    android:textColor="#6B6770"
                                    android:textSize="10sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:text="-"
                                    android:textColor="#1C1B1F"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_info_block"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:letterSpacing="0.04"
                                    android:text="PERIODE"
                                    android:textColor="#6B6770"
                                    android:textSize="10sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:text="-"
                                    android:textColor="#1C1B1F"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:fontFamily="@font/poppins"
                            android:letterSpacing="0.04"
                            android:text="FOTO METER"
                            android:textColor="#6B6770"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_foto_meter"
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_info_block"
                            android:scaleType="centerCrop"
                            android:src="@drawable/logo" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pilih_foto_meter"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/poppins"
                            android:text="Pilih Foto Meter"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:backgroundTint="#F4EEEC"
                            app:cornerRadius="22dp"
                            app:elevation="0dp"
                            app:strokeWidth="0dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="ID Pelanggan"
                            app:boxBackgroundColor="#FFFFFF"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxStrokeColor="#C8102E"
                            app:boxStrokeWidth="1.5dp"
                            app:hintTextColor="#C8102E"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_pelanggan_foto_meter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:textSize="15sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ═══════════ SECTION: BACA ULANG ═══════════ -->
            <LinearLayout
                android:id="@+id/div_input_baca_ulang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E6E0E1"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins"
                            android:letterSpacing="0.08"
                            android:text="INFORMASI AKTIF"
                            android:textColor="#6B6770"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_info_block"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:letterSpacing="0.04"
                                    android:text="CABANG"
                                    android:textColor="#6B6770"
                                    android:textSize="10sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:text="-"
                                    android:textColor="#1C1B1F"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_info_block"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:letterSpacing="0.04"
                                    android:text="PERIODE"
                                    android:textColor="#6B6770"
                                    android:textSize="10sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:text="-"
                                    android:textColor="#1C1B1F"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:hint="ID Pelanggan"
                            app:boxBackgroundColor="#FFFFFF"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxStrokeColor="#C8102E"
                            app:boxStrokeWidth="1.5dp"
                            app:hintTextColor="#C8102E"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_pelanggan_baca_ulang"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:textSize="15sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ═══════ STICKY BOTTOM: Buka Data button ═══════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FCF9F8"
        android:elevation="6dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_buka_data"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:fontFamily="@font/poppins"
            android:text="Buka Data Bendel"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#C8102E"
            app:cornerRadius="28dp"
            app:elevation="0dp" />

    </LinearLayout>

</LinearLayout>