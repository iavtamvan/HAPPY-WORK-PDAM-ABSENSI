<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cvKlik"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="4dp"
    android:layout_marginRight="4dp"
    android:layout_marginBottom="2dp"
    android:orientation="vertical"
    app:cardElevation="4dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_klik"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginRight="4dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <TextView
            android:id="@+id/tv_no"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="55dp"
            android:fontFamily="@font/audiowide"
            android:gravity="center"
            android:text="3"
            android:textColor="#164E4E4E"
            android:textSize="40dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="3dp"
            android:layout_marginTop="4dp"
            android:layout_marginRight="3dp"
            android:layout_marginBottom="5dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:id="@+id/div_nolangg"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:text="ID Pelanggan: "
                                        android:textColor="@color/grey"
                                        android:textSize="10dp" />

                                    <TextView
                                        android:id="@+id/tv_list_bendel_nolangg"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="left"
                                        android:text="--"
                                        android:textColor="@color/red"
                                        android:textSize="12dp" />


                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/div_copy"
                                    android:layout_width="25dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginLeft="4dp"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:layout_marginLeft="2dp"
                                        android:src="@drawable/copy" />
                                </LinearLayout>


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="2dp"
                                    android:layout_marginRight="2dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:text="Nama: "
                                        android:textColor="@color/grey"
                                        android:textSize="10dp" />

                                    <TextView
                                        android:id="@+id/tv_list_bendel_nama"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="left"
                                        android:gravity="center"
                                        android:text="--"
                                        android:textColor="@color/black"
                                        android:textSize="12dp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="2dp"
                                    android:layout_marginRight="2dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:text="Alamat: "
                                        android:textColor="@color/grey"
                                        android:textSize="10dp" />

                                    <TextView
                                        android:id="@+id/tv_list_bendel_alamat"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="left"
                                        android:text="--"
                                        android:textColor="@color/black"
                                        android:textSize="12dp" />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:text="Lalu: "
                                        android:textColor="@color/grey"
                                        android:textSize="10dp" />

                                    <TextView
                                        android:id="@+id/tv_list_bendel_lalu"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:text="--"
                                        android:textColor="@color/black"
                                        android:textSize="12dp" />

                                </LinearLayout>


                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:text="DISM: "
                                        android:textColor="@color/grey"
                                        android:textSize="10dp" />

                                    <TextView
                                        android:id="@+id/tv_list_bendel_dism"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="left"
                                        android:text="--"
                                        android:textColor="@color/black"
                                        android:textSize="12dp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="2dp"
                                    android:layout_marginRight="2dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:text="ST: "
                                        android:textColor="@color/grey"
                                        android:textSize="10dp" />

                                    <TextView
                                        android:id="@+id/tv_list_bendel_st"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:gravity="center"
                                        android:text="--"
                                        android:textColor="@color/black"
                                        android:textSize="12dp" />

                                </LinearLayout>



                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <LinearLayout
                                        android:id="@+id/div_tandai"
                                        android:layout_width="wrap_content"
                                        android:layout_height="35dp"
                                        android:layout_gravity="end"
                                        android:layout_marginLeft="3dp"
                                        android:gravity="end"
                                        android:orientation="horizontal">

                                        <ImageView
                                            android:id="@+id/iv_tandai"
                                            android:layout_width="50dp"
                                            android:layout_height="match_parent"
                                            android:src="@drawable/mark_plg_before" />

                                        <ImageView
                                            android:id="@+id/iv_tandai_success"
                                            android:layout_width="50dp"
                                            android:layout_height="match_parent"
                                            android:src="@drawable/mark_plg"
                                            android:visibility="gone" />

                                        <!--                                    <TextView-->
                                        <!--                                        android:id="@+id/tv_list_bendel_dibuat"-->
                                        <!--                                        android:layout_width="match_parent"-->
                                        <!--                                        android:layout_height="match_parent"-->
                                        <!--                                        android:layout_marginLeft="10dp"-->
                                        <!--                                        android:layout_weight="1"-->
                                        <!--                                        android:gravity="center"-->
                                        <!--                                        android:text="Generate by System"-->
                                        <!--                                        android:textColor="@color/dash_v2_bluedark"-->
                                        <!--                                        android:textSize="11dp"-->
                                        <!--                                        android:textStyle="italic" />-->

                                    </LinearLayout>
                                </LinearLayout>


                            </LinearLayout>



                        </LinearLayout>
                    </LinearLayout>

<!--                    <LinearLayout-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_marginTop="2dp"-->
<!--                        android:orientation="horizontal">-->

<!--                        <TextView-->
<!--                            android:layout_width="wrap_content"-->
<!--                            android:layout_height="match_parent"-->
<!--                            android:gravity="left|center_vertical"-->
<!--                            android:text="Dibuat : "-->
<!--                            android:textColor="@color/grey"-->
<!--                            android:textSize="12dp" />-->

<!--                        <TextView-->
<!--                            android:id="@+id/tv_list_bendel_dibuat"-->
<!--                            android:layout_width="wrap_content"-->
<!--                            android:layout_height="match_parent"-->
<!--                            android:layout_marginLeft="10dp"-->
<!--                            android:gravity="left|center_vertical"-->
<!--                            android:text="Generate by System"-->
<!--                            android:textColor="@color/dash_v2_bluedark"-->
<!--                            android:textSize="11dp"-->
<!--                            android:textStyle="italic" />-->

<!--                    </LinearLayout>-->


                </LinearLayout>
            </LinearLayout>


        </LinearLayout>
    </androidx.cardview.widget.CardView>


</LinearLayout>