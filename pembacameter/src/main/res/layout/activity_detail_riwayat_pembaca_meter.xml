                                android:text="Pemakaian"
                                android:textSize="12dp" />

                            <TextView
                                android:id="@+id/tv_pemakaian_bln_lalu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:text="-- - --"
                                android:textColor="@color/md_material_blue_600"
                                android:textSize="11dp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:text="Petugas"
                                android:textSize="12dp" />

                            <TextView
                                android:id="@+id/tv_petugas_bln_lalu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:text="--"
                                android:textColor="@color/black"
                                android:textSize="11dp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:text="Foto Meter"
                                android:textSize="12dp" />

                            <ImageView
                                android:id="@+id/iv_foto_meter_bln_lalu"
                                android:layout_width="match_parent"
                                android:layout_height="200dp"
                                android:src="@drawable/im_good_day" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
