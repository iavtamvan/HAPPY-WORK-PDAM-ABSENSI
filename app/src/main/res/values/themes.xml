<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme tanpa ActionBar -->
    <style name="Theme.HappyWork" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">?attr/colorPrimaryDark</item>

        <!-- Biar konten tidak mentok status bar -->
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <!-- Kalau ada Activity tertentu yang butuh ActionBar -->
    <style name="Theme.HappyWork.DarkActionBar" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryDark</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="Theme.HappyWork.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.HappyWork.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

</resources>
